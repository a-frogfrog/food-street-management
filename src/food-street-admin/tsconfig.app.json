{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    /* path alias */
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@types/*": ["src/types/*"],
      "@frog/*": ["packages/*"],
      "@frog/components/*": ["packages/components/*"],
      "@frog/utils/*": ["packages/utils/*"],
      "@frog/hooks/*": ["packages/hooks/*"],
      "@frog/constants/*": ["packages/constants/*"],
      "@frog/directives/*": ["packages/directives/*"],
      "@frog/event/*": ["packages/event/*"],
      "@frog/request/*": ["packages/request/*"]
    },
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true

    /* TypeScript*/
    // "preserveConstEnums":true,
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.vue"
  ]
}
